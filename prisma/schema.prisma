generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Users & Auth ─────────────────────────────────────────────────────────────

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  password     String
  role         UserRole @default(PATIENT)
  phone        String?
  resetToken   String?
  resetExpiry  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // role-specific profiles
  patient       Patient?
  medicalStaff  MedicalStaff?
  caregiver     Caregiver?
  insuranceRep  InsuranceRep?
  govRep        GovernmentRep?
}

enum UserRole {
  ADMIN
  HOSPITAL_MANAGEMENT
  MEDICAL_STAFF
  PATIENT
  CAREGIVER
  INSURANCE
  GOVERNMENT
}

// ── Patient ───────────────────────────────────────────────────────────────────

model Patient {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName   String
  lastName    String
  gender      String
  dateOfBirth DateTime
  bloodType   String?
  address     String?
  phone       String?
  insurance   String?
  emergencyContact String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  appointments    Appointment[]
  medicalRecords  MedicalRecord[]
  bills           Bill[]
}

// ── Medical Staff ─────────────────────────────────────────────────────────────

model MedicalStaff {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  staffType    StaffType
  specialty    String?
  licenseNo    String?
  department   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  appointments Appointment[]
}

enum StaffType {
  // Clinical / Medical
  DOCTOR
  SURGEON
  SPECIALIST
  RESIDENT_DOCTOR
  INTERN_DOCTOR
  NURSE
  SENIOR_NURSE
  MIDWIFE
  NURSE_ANESTHETIST
  // Allied Health
  CLINICAL_OFFICER
  PHARMACIST
  PHARMACY_TECH
  LAB_TECH
  LAB_SCIENTIST
  RADIOLOGIST
  RADIOGRAPHER
  PHYSIOTHERAPIST
  OCCUPATIONAL_THERAPIST
  NUTRITIONIST_DIETITIAN
  SPEECH_THERAPIST
  OPTOMETRIST
  DENTAL_OFFICER
  DENTAL_TECH
  // Emergency & Critical Care
  PARAMEDIC
  EMT
  ICU_SPECIALIST
  ANESTHESIOLOGIST
  // Mental Health
  PSYCHIATRIST
  PSYCHOLOGIST
  COUNSELOR
  // Support & Admin
  RECEPTIONIST
  MEDICAL_RECORDS_OFFICER
  HEALTH_INFORMATION_OFFICER
  SOCIAL_WORKER
  CHAPLAIN
  PORTER
  CLEANER
  SECURITY
}

// ── Caregiver ─────────────────────────────────────────────────────────────────

model Caregiver {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  relation  String?
  createdAt DateTime @default(now())
}

// ── Insurance Rep ─────────────────────────────────────────────────────────────

model InsuranceRep {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company     String
  licenseNo   String?
  createdAt   DateTime @default(now())
}

// ── Government / Regulatory Rep ───────────────────────────────────────────────

model GovernmentRep {
  id         Int      @id @default(autoincrement())
  userId     Int      @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  agency     String
  position   String?
  createdAt  DateTime @default(now())
}

// ── Appointments ──────────────────────────────────────────────────────────────

model Appointment {
  id            Int               @id @default(autoincrement())
  patientId     Int
  patient       Patient           @relation(fields: [patientId], references: [id])
  staffId       Int?
  staff         MedicalStaff?     @relation(fields: [staffId], references: [id])
  date          DateTime
  time          String
  reason        String?
  status        AppointmentStatus @default(PENDING)
  notes         String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

// ── Medical Records ───────────────────────────────────────────────────────────

model MedicalRecord {
  id          Int      @id @default(autoincrement())
  patientId   Int
  patient     Patient  @relation(fields: [patientId], references: [id])
  diagnosis   String
  treatment   String?
  prescription String?
  notes       String?
  visitDate   DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ── Billing ───────────────────────────────────────────────────────────────────

model Bill {
  id            Int           @id @default(autoincrement())
  patientId     Int
  patient       Patient       @relation(fields: [patientId], references: [id])
  amount        Float
  description   String?
  status        BillStatus    @default(UNPAID)
  paymentMethod String?
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

enum BillStatus {
  UNPAID
  PAID
  PARTIAL
  WAIVED
}

// ── Tasks ─────────────────────────────────────────────────────────────────────

model Task {
  id          Int        @id @default(autoincrement())
  title       String
  description String?
  assignedTo  Int?
  status      TaskStatus @default(PENDING)
  dueDate     DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

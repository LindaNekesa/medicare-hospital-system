generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // directUrl is used for migrations (bypasses pgBouncer)
  directUrl = env("DIRECT_URL")
}

// ── Users & Auth ─────────────────────────────────────────────────────────────

model User {
  id           Int       @id @default(autoincrement())
  name         String
  email        String    @unique
  password     String
  role         String    @default("PATIENT")
  phone        String?
  resetToken   String?
  resetExpiry  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  failedAttempts Int      @default(0)
  lockedUntil    DateTime?

  patient           Patient?
  medicalStaff      MedicalStaff?
  caregiver         Caregiver?
  insuranceRep      InsuranceRep?
  govRep            GovernmentRep?
  clinicalSummaries ClinicalSummary[]
  availability      DoctorAvailability[]

  // Indexes for fast auth lookups
  @@index([email])
  @@index([role])
  @@index([resetToken])
}

// ── Patient ───────────────────────────────────────────────────────────────────

model Patient {
  id               Int      @id @default(autoincrement())
  userId           Int      @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName        String
  lastName         String
  gender           String
  dateOfBirth      DateTime
  bloodType        String?
  address          String?
  phone            String?
  insurance        String?
  emergencyContact String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  appointments   Appointment[]
  medicalRecords MedicalRecord[]
  bills          Bill[]

  // Indexes for search and date-range queries (critical for 2000+/day)
  @@index([firstName, lastName])
  @@index([phone])
  @@index([createdAt])
  @@index([insurance])
}

// ── Medical Staff ─────────────────────────────────────────────────────────────

model MedicalStaff {
  id         Int      @id @default(autoincrement())
  userId     Int      @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  staffType  String
  specialty  String?
  licenseNo  String?
  department String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  appointments Appointment[]

  @@index([staffType])
  @@index([department])
}

// ── Caregiver ─────────────────────────────────────────────────────────────────

model Caregiver {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  relation  String?
  createdAt DateTime @default(now())
}

// ── Insurance Rep ─────────────────────────────────────────────────────────────

model InsuranceRep {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   String
  licenseNo String?
  createdAt DateTime @default(now())
}

// ── Government / Regulatory Rep ───────────────────────────────────────────────

model GovernmentRep {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  agency    String
  position  String?
  createdAt DateTime @default(now())
}

// ── Appointments ──────────────────────────────────────────────────────────────

model Appointment {
  id        Int           @id @default(autoincrement())
  patientId Int
  patient   Patient       @relation(fields: [patientId], references: [id])
  staffId   Int?
  staff     MedicalStaff? @relation(fields: [staffId], references: [id])
  date      DateTime
  time      String
  reason    String?
  status    String        @default("PENDING")
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  // Critical indexes — appointments are the highest-volume table
  @@index([patientId])
  @@index([staffId])
  @@index([date])
  @@index([status])
  @@index([date, status])          // composite: today's pending appointments
  @@index([patientId, date])       // composite: patient appointment history
  @@index([staffId, date])         // composite: doctor's daily schedule
}

// ── Medical Records ───────────────────────────────────────────────────────────

model MedicalRecord {
  id           Int      @id @default(autoincrement())
  patientId    Int
  patient      Patient  @relation(fields: [patientId], references: [id])
  diagnosis    String
  treatment    String?
  prescription String?
  notes        String?
  visitDate    DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  clinicalSummary ClinicalSummary?

  @@index([patientId])
  @@index([visitDate])
  @@index([patientId, visitDate])
}

// ── Clinical Summary ──────────────────────────────────────────────────────────

model ClinicalSummary {
  id               Int           @id @default(autoincrement())
  recordId         Int           @unique
  authorId         Int
  chiefComplaint   String?
  historyOfIllness String?
  physicalExam     String?
  investigations   String?
  diagnosis        String
  differentials    String?
  managementPlan   String?
  prognosis        String?
  doctorSignature  String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  record MedicalRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  author User          @relation(fields: [authorId], references: [id])

  @@index([authorId])
  @@index([recordId])
}

// ── Billing ───────────────────────────────────────────────────────────────────

model Bill {
  id            Int       @id @default(autoincrement())
  patientId     Int
  patient       Patient   @relation(fields: [patientId], references: [id])
  amount        Float
  description   String?
  status        String    @default("UNPAID")
  paymentMethod String?
  paidAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([patientId])
  @@index([status])
  @@index([createdAt])
  @@index([patientId, status])
}

// ── Tasks ─────────────────────────────────────────────────────────────────────

model Task {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  assignedTo  Int?
  status      String    @default("PENDING")
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([assignedTo])
  @@index([status])
  @@index([dueDate])
}

// ── Audit Log ─────────────────────────────────────────────────────────────────

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  action    String
  entity    String
  entityId  Int?
  timestamp DateTime @default(now())

  // Audit logs are append-only and queried by user or time range
  @@index([userId])
  @@index([timestamp])
  @@index([entity, entityId])
}

// ── Hospital Settings ─────────────────────────────────────────────────────────

model HospitalSettings {
  id                 Int      @id @default(autoincrement())
  hospitalName       String
  emailNotifications String   @default("ENABLED")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// ── Department ────────────────────────────────────────────────────────────────

model Department {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Doctor Availability ───────────────────────────────────────────────────────

model DoctorAvailability {
  id        Int    @id @default(autoincrement())
  doctorId  Int                          // matches User.id (Int)
  dayOfWeek Int                          // 0 = Sunday, 6 = Saturday
  startTime String                       // "09:00"
  endTime   String                       // "17:00"

  doctor User @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([dayOfWeek])
  @@unique([doctorId, dayOfWeek])        // one slot per doctor per day
}
